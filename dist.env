# Modèle de configuration — copier vers .env puis REMPLACER toutes les valeurs « a_changer ».
# Ne jamais committer de vrais secrets : .env est ignoré par git.

# Configuration base de données PostgreSQL
POSTGRES_DB=gesto_note_db
POSTGRES_USER=gesto_note_db_user
POSTGRES_PASSWORD=a_changer_mot_de_passe_base

# Identifiants de connexion à l'application
APP_USERNAME=admin
APP_PASSWORD=a_changer_mot_de_passe_application

# Port d'écoute HTTP de l'application
DOCKER_UI_PORT=8080
